{
  "name": "mouse-trouble",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:party": "npx partykit dev",
    "prebuild": "node scripts/generate-kitchen-layout-module.mjs && node scripts/apply-mouse-skin.mjs && node scripts/optimize-runtime-images.mjs && node scripts/optimize-glb.mjs",
    "build": "vite build",
    "deploy:cf": "npm run build && wrangler deploy",
    "deploy:party": "npx partykit deploy",
    "deploy": "npm run deploy:cf && npm run deploy:party",
    "mouse:skin": "node scripts/apply-mouse-skin.mjs",
    "textures:analyze": "node scripts/analyze-texture-atlas.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "nipplejs": "^1.0.1",
    "partysocket": "^1.1.16",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "meshoptimizer": "^1.1.0",
    "partykit": "^0.0.115",
    "sharp": "^0.34.5",
    "vite": "^6.2.0",
    "wrangler": "^4.80.0"
  }
}
